[Unit]
Description=Zoomies control plane
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/zoomies
Environment=NODE_ENV=production
Environment=PORT=3000
Environment=HOSTNAME=0.0.0.0
ExecStart=/usr/bin/node /opt/zoomies/.next/standalone/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
