{
  "name": "zoomies",
  "version": "0.0.0",
  "description": "Control plane for NGINX reverse proxy: config rendering, validation, and reload orchestration.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zoomies": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "pnpm run build:web && pnpm run build:cli",
    "build:web": "next build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "start": "next start",
    "cli": "tsx src/index.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.cli.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "nginx",
    "reverse-proxy",
    "proxy-manager",
    "control-plane"
  ],
  "author": "Ryan Yannelli",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yannelli/zoomies.git"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "execa": "^9.6.1",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
